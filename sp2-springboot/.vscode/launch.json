{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "TlbankLendingApplication (dev)",
      "request": "launch",
      "mainClass": "com.tlbank.lending.TlbankLendingApplication",
      "projectName": "tlbank-lending",
      "args": "--spring.profiles.active=dev",
      "vmArgs": "-Dspring.profiles.active=dev",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Prepare Dev Launch",
      "env": {
        "JAVA_HOME": "/Library/Java/JavaVirtualMachines/jdk-17.jdk/Contents/Home"
      }
    }
  ]
}
