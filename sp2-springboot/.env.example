# TLBank Digital Lending Platform - Docker environment variables
# Copy this file to .env and adjust values before running docker-compose up

DB_NAME=TLBankLending
DB_USERNAME=tlbank_app
DB_PASSWORD=ChangeMe@2024
DB_SA_PASSWORD=ChangeMe@SA2024

SPRING_PROFILES_ACTIVE=staging
SPRING_DATASOURCE_URL=jdbc:sqlserver://sqlserver:1433;databaseName=TLBankLending;encrypt=true;trustServerCertificate=true
SPRING_DATASOURCE_USERNAME=tlbank_app
SPRING_DATASOURCE_PASSWORD=ChangeMe@2024

APP_SESSION_TIMEOUT=30m
APP_OTP_EXPIRE_MINUTES=5
APP_OTP_MAX_RETRY=3
APP_UPLOAD_PATH=/app/uploads
