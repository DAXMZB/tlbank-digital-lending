# .env.example（複製為 .env 後填入實際值）

# --- 資料庫設定 ---
DB_NAME=Company
DB_ROOT_PASSWORD=your_password_here

# --- Spring Boot 資料庫連線（本機 IDE / mvn spring-boot:run 用 localhost）---
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/Company?useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_password_here

# --- Gmail SMTP 設定 ---
GMAIL_USER=your_email@gmail.com
GMAIL_PWD=your_app_password_here
